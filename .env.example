# GitHub Secrets - These are injected by GitHub Actions
# Do NOT commit actual values to this file

# SMTP authentication (required)
MENU_SMTP_USER=sender@gmail.com
MENU_SMTP_PASS=your-app-password-or-token

# Translation API key (required for Chinese translation)
OPENAI_API_KEY=sk-xxx... or openrouter-key...

# Note: Other configuration can be found in config.yml (non-sensitive settings)
